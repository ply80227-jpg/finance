{
  "quote": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "FetchResult",
    "description": "Standard envelope returned by quote/history/news.",
    "type": "object",
    "required": [
      "ok",
      "provider",
      "symbol",
      "market",
      "data",
      "errors",
      "schema_version"
    ],
    "properties": {
      "ok": {
        "type": "boolean"
      },
      "provider": {
        "type": "string",
        "description": "Which provider served this result, or 'none' on full failure."
      },
      "symbol": {
        "type": "string"
      },
      "market": {
        "type": "string",
        "enum": [
          "cn",
          "hk",
          ""
        ]
      },
      "data": {
        "type": "object",
        "description": "Payload — shape depends on command (see examples).",
        "additionalProperties": true
      },
      "error": {
        "type": [
          "string",
          "null"
        ],
        "description": "Legacy semicolon-joined error string. Prefer `errors`."
      },
      "errors": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "provider",
            "message"
          ],
          "properties": {
            "provider": {
              "type": "string"
            },
            "message": {
              "type": "string"
            }
          }
        }
      },
      "schema_version": {
        "type": "integer",
        "const": 2
      }
    }
  },
  "batch_quote": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "BatchQuoteResult",
    "description": "Envelope returned by batch quote. Individual items follow FetchResult.",
    "type": "object",
    "required": [
      "ok",
      "count",
      "items",
      "schema_version"
    ],
    "properties": {
      "ok": {
        "type": "boolean",
        "description": "True iff at least one item succeeded. Use per-item `ok` for fine-grained checks."
      },
      "count": {
        "type": "integer",
        "minimum": 0
      },
      "items": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/FetchResult"
        }
      },
      "schema_version": {
        "type": "integer",
        "const": 2
      }
    },
    "$defs": {
      "FetchResult": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "FetchResult",
        "description": "Standard envelope returned by quote/history/news.",
        "type": "object",
        "required": [
          "ok",
          "provider",
          "symbol",
          "market",
          "data",
          "errors",
          "schema_version"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "provider": {
            "type": "string",
            "description": "Which provider served this result, or 'none' on full failure."
          },
          "symbol": {
            "type": "string"
          },
          "market": {
            "type": "string",
            "enum": [
              "cn",
              "hk",
              ""
            ]
          },
          "data": {
            "type": "object",
            "description": "Payload — shape depends on command (see examples).",
            "additionalProperties": true
          },
          "error": {
            "type": [
              "string",
              "null"
            ],
            "description": "Legacy semicolon-joined error string. Prefer `errors`."
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "provider",
                "message"
              ],
              "properties": {
                "provider": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "schema_version": {
            "type": "integer",
            "const": 2
          }
        }
      }
    }
  },
